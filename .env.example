# --- Database -----------------------------------------------------------------
DATABASE_URL=postgresql://teacherflow:teacherflow@localhost:5432/teacherflow

# --- Auth ---------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Storage ------------------------------------------------------------------
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=20

# --- Google (login + Calendar/Meet) -------------------------------------------
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs to add (replace localhost with your domain in prod):
#   - http://localhost:3000/api/auth/callback/google         (login)
#   - http://localhost:3000/api/google/calendar/callback     (Calendar/Meet)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Seed defaults ------------------------------------------------------------
DEFAULT_TEACHER_EMAIL=profesora@teacherflow.local
DEFAULT_TEACHER_PASSWORD=changeme123
DEFAULT_TEACHER_NAME=Profesora
DEFAULT_STUDENT_EMAIL=alumno@teacherflow.local
DEFAULT_STUDENT_PASSWORD=changeme123

# --- AI (notebook extraction + semantic search) -------------------------------
# OpenAI: used for embeddings (text-embedding-3-small is cheap and multilingual).
# Google: used for extracting structured data from notebook docs (Gemini).
OPENAI_API_KEY=
GOOGLE_API_KEY=
AI_EMBED_MODEL=text-embedding-3-small
AI_EXTRACT_MODEL=gemini-2.5-flash
