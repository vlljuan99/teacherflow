# --- Database -----------------------------------------------------------------
# Local: arranca Postgres con `docker compose up -d db` y deja esta URL tal cual.
# Producción: la inyecta docker-compose (deploy/.env -> POSTGRES_PASSWORD).
DATABASE_URL=postgresql://teacherflow:teacherflow@localhost:5432/teacherflow?schema=public

# --- Auth ---------------------------------------------------------------------
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Storage ------------------------------------------------------------------
# STORAGE_BACKEND=local        -> archivos en UPLOAD_DIR (disco local)
# STORAGE_BACKEND=azure        -> Azure Blob Storage (requiere las 3 vars de abajo)
STORAGE_BACKEND=local
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=20

# Azure Blob Storage (solo si STORAGE_BACKEND=azure)
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER=english

# --- Google (login + Calendar/Meet + Drive + Docs) ----------------------------
# Crea OAuth client en https://console.cloud.google.com/apis/credentials (Web).
# Authorized redirect URIs (añade los dos en desarrollo y los dos en producción):
#   - https://<dominio>/api/auth/callback/google         (login)
#   - https://<dominio>/api/google/calendar/callback     (Calendar/Meet/Drive/Docs)
# APIs que hay que activar en Google Cloud Console (APIs & Services -> Library):
#   - Google Calendar API
#   - Google Drive API
#   - Google Docs API
#   - Google Meet API
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Seed defaults ------------------------------------------------------------
DEFAULT_TEACHER_EMAIL=profesora@teacherflow.local
DEFAULT_TEACHER_PASSWORD=changeme123
DEFAULT_TEACHER_NAME=Profesora
DEFAULT_STUDENT_EMAIL=alumno@teacherflow.local
DEFAULT_STUDENT_PASSWORD=changeme123

# --- Email (recordatorios de clase) -------------------------------------------
# Lo más barato: Gmail SMTP con "App password" (gratis, ~500 envíos/día).
# 1) https://myaccount.google.com/security  -> activa 2FA si no la tienes.
# 2) https://myaccount.google.com/apppasswords -> genera una "App password".
# 3) Pega el correo en SMTP_USER y la app password en SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TeacherFlow <profesora@gmail.com>"

# URL pública del portal (se usa en los emails de recordatorio).
APP_URL=http://localhost:3000

# --- WhatsApp (Meta WhatsApp Cloud API) ---------------------------------------
# Recordatorios por WhatsApp. Cada alumno elige su canal (email / WhatsApp /
# ambos) en su ficha. Los mensajes proactivos requieren una PLANTILLA aprobada.
# 1) Crea una app en https://developers.facebook.com/ (producto WhatsApp).
# 2) Coge el "Phone number ID" y un token permanente (system user).
# 3) Crea y aprueba una plantilla llamada "class_reminder" (idioma "en") con
#    cuerpo de 3 variables, p. ej.:
#      Hi {{1}}! Your English class "{{2}}" starts at {{3}}. See you soon! 👋
#    Orden de variables: {{1}} nombre, {{2}} título de la clase, {{3}} hora.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_REMINDER_TEMPLATE=class_reminder
WHATSAPP_TEMPLATE_LANG=en
# Si los teléfonos de los alumnos no llevan prefijo de país, ponlo aquí (ej: 34).
WHATSAPP_DEFAULT_COUNTRY_CODE=

# Token compartido para llamar al endpoint de cron (/api/cron/class-reminders).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=

# --- AI (cuadernos + búsqueda semántica + placement test) ---------------------
# OpenAI -> embeddings (text-embedding-3-small).
# Google -> extracción estructurada con Gemini.
OPENAI_API_KEY=
GOOGLE_API_KEY=
AI_EMBED_MODEL=text-embedding-3-small
AI_EXTRACT_MODEL=gemini-2.5-flash
