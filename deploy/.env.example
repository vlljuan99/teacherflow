# /opt/teacherflow/.env — variables del stack base (Caddy + Postgres + app)

# Postgres
POSTGRES_PASSWORD=cambia-esto-por-una-contrasena-larga

# Host público: o un dominio (ej. teacherflow.tudominio.es) o sslip.io con la IP
