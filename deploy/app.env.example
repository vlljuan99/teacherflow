# /opt/teacherflow/app.env — variables que recibe el contenedor de la app.
# DATABASE_URL y UPLOAD_DIR se inyectan desde docker-compose.yml.
TZ=Europe/Madrid

# Auth.js
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
NEXTAUTH_URL=https://teacherflow.tudominio.es

# Google OAuth + Calendar + Drive + Docs + Meet
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Tamaño máximo de upload (MB)
MAX_UPLOAD_MB=20

# Seed inicial (se usa por prisma/seed.ts si lo lanzas a mano)
DEFAULT_TEACHER_EMAIL=profesora@teacherflow.local
DEFAULT_TEACHER_PASSWORD=changeme123
DEFAULT_TEACHER_NAME=Profesora
DEFAULT_STUDENT_EMAIL=alumno@teacherflow.local
DEFAULT_STUDENT_PASSWORD=changeme123

# IA
OPENAI_API_KEY=
GOOGLE_API_KEY=
AI_EMBED_MODEL=text-embedding-3-small
AI_EXTRACT_MODEL=gemini-2.5-flash
